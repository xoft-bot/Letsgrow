rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /members/{memberId} {
      allow read:  if true;
      allow write: if request.auth != null;
    }
    match /approvedEmails/{email} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }
    match /club/{document} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }
    match /settings/{document} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }
    match /contributions/{document} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }
    match /investments/{document} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }
    match /notifications/{document} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }
    match /loans/{document} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }
    match /memberLoanProfiles/{document} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }
    match /committees/{document} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }
    match /estates/{document} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }
    match /juniors/{document} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }
    match /events/{document} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }
    match /clubIncome/{document} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }
    match /clubExpenses/{document} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── NEW COLLECTIONS ────────────────────────────────────────
    match /messages/{document} {
      // All members are vetted — any authenticated user can read messages.
      // Admin needs to read all incoming messages; members see their own.
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }
    match /fines/{document} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }
    match /dividends/{document} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }
    match /diasporaFees/{document} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }
    match /registrationFees/{document} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
